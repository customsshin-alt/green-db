# PostgreSQL 클라우드 DB 사용 시 이 파일을 복사해 secrets.toml 로 저장하고 값을 채우세요.
# secrets.toml 은 .gitignore 에 포함되어 GitHub 에 올라가지 않습니다.
# Streamlit Cloud: 대시보드 > 앱 > Settings > Secrets 에 아래 형식으로 입력합니다.

[postgres]
host = "your-db-host.example.com"
port = 5432
database = "your_database_name"
user = "your_username"
password = "your_password"

# 또는 연결 URL 하나만 넣을 수도 있습니다.
# [postgres]
# url = "postgresql://user:password@host:5432/dbname"
